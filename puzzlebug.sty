% ---------------------------------------------------------------------------------------
% PUZZLEBUG NUMBERING SYSTEM v1
% P U Z Z L E B U G
%  A B B C D E E E
% A is version number this numbering system (currently 1)
% BB is issue number (hex)
% C is edit number (hex, 0 for draft, 1 for first release, 2 for first release after corrections, etc)
% D is 0 for test print, 1 for print, 2 for pdf
% if D==0:
%   EEE is 123
% if D==1:
%   E,EE is print run number and size of print run (hex)
% if D==2:
%   EEE is PDF
% % INPUTS
% % #1: NUMBERING VERSION
% % #2: ISSUE NuMBER
% % #3: EDIT NUMBER
% % #4: TYPE (0=test, 1=print, 2=pdf)
% % #5: if TYPE==1 PRINT RUN NUMBER else <IGNORED>
% % #6: if TYPE==1 PRINT RUN SIZE else <IGNORED>
\newcommand{\bugcode}[6]{P\StrChar{\nhex{1}{#1}}{1}U\StrChar{\nhex{2}{#2}}{1}Z\StrChar{\nhex{2}{#2}}{2}Z\StrChar{\nhex{1}{#3}}{1}L#4E\ifthenelse{\equal{#4}{0}}{1}{}\ifthenelse{\equal{#4}{1}}{\StrChar{\nhex{1}{#5}}{1}}{}\ifthenelse{\equal{#4}{2}}{P}{}B\ifthenelse{\equal{#4}{0}}{2}{}\ifthenelse{\equal{#4}{1}}{\StrChar{\nhex{2}{#6}}{1}}{}\ifthenelse{\equal{#4}{2}}{D}{}U\ifthenelse{\equal{#4}{0}}{3}{}\ifthenelse{\equal{#4}{1}}{\StrChar{\nhex{2}{#6}}{2}}{}\ifthenelse{\equal{#4}{2}}{F}{}G}

