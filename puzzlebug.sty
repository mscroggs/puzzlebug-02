\newcommand{\pagenum}[1]{
\begin{scope}[shift={(3.7125,0.8)}]
\draw[line width=1pt,line join=round,rounded corners=1mm] (-0.25,-0.25) rectangle (0.25,0.25);
\ifthenelse{\equal{#1}{1}}{
\fill[black] (0,0) circle (1.8pt);
}{}
\ifthenelse{\equal{#1}{2}}{
\fill[black] (0.1,0.1) circle (1.8pt);
\fill[black] (-0.1,-0.1) circle (1.8pt);
}{}
\ifthenelse{\equal{#1}{3}}{
\fill[black] (0,0) circle (1.8pt);
\fill[black] (0.125,0.125) circle (1.8pt);
\fill[black] (-0.125,-0.125) circle (1.8pt);
}{}
\ifthenelse{\equal{#1}{4}}{
\fill[black] (0.1,0.1) circle (1.8pt);
\fill[black] (0.1,-0.1) circle (1.8pt);
\fill[black] (-0.1,0.1) circle (1.8pt);
\fill[black] (-0.1,-0.1) circle (1.8pt);
}{}
\ifthenelse{\equal{#1}{5}}{
\fill[black] (0,0) circle (1.8pt);
\fill[black] (0.125,0.125) circle (1.8pt);
\fill[black] (0.125,-0.125) circle (1.8pt);
\fill[black] (-0.125,0.125) circle (1.8pt);
\fill[black] (-0.125,-0.125) circle (1.8pt);
}{}
\ifthenelse{\equal{#1}{6}}{
\fill[black] (0.1,-0.145) circle (1.8pt);
\fill[black] (0.1,0) circle (1.8pt);
\fill[black] (0.1,0.145) circle (1.8pt);
\fill[black] (-0.1,-0.145) circle (1.8pt);
\fill[black] (-0.1,0) circle (1.8pt);
\fill[black] (-0.1,0.145) circle (1.8pt);
}{}
\end{scope}
}

% PUZZLEBUG NUMBERING SYSTEM v1
% P U Z Z L E B U G
%  A B B C D E E E
% A is version number this numbering system (currently 1)
% BB is issue number (hex)
% C is edit number (hex, 0 for draft, 1 for first release, 2 for first release after corrections, etc)
% D is 0 for test print, 1 for print, 2 for pdf
% if D==0:
%   EEE is 123
% if D==1:
%   E,EE is print run number and size of print run (hex)
% if D==2:
%   EEE is PDF
%% inputs:
%%  NUMBERING VERSION
%%  ISSUE NuMBER
%%  EDIT NUMBER
%%  TYPE (0=test, 1=print, 2=pdf)
%%  if TYPE==1 PRINT RUN NUMBER else <IGNORED>
%%  if TYPE==1 PRINT RUN SIZE else <IGNORED>
\newcommand{\bugcode}[6]{P\StrChar{\nhex{1}{#1}}{1}U\StrChar{\nhex{2}{#2}}{1}Z\StrChar{\nhex{2}{#2}}{2}Z\StrChar{\nhex{1}{#3}}{1}L#4E\ifthenelse{\equal{#4}{0}}{1}{}\ifthenelse{\equal{#4}{1}}{\StrChar{\nhex{1}{#5}}{1}}{}\ifthenelse{\equal{#4}{2}}{P}{}B\ifthenelse{\equal{#4}{0}}{2}{}\ifthenelse{\equal{#4}{1}}{\StrChar{\nhex{2}{#6}}{1}}{}\ifthenelse{\equal{#4}{2}}{D}{}U\ifthenelse{\equal{#4}{0}}{3}{}\ifthenelse{\equal{#4}{1}}{\StrChar{\nhex{2}{#6}}{2}}{}\ifthenelse{\equal{#4}{2}}{F}{}G}

\newcommand{\scissor}[1][]{\begin{scope}[#1]
\draw[fill=white] (-0.1,0.7) arc (180:{90+tan(0.2/1.1)}:1mm) -- (0,0.8) -- (0.2,-0.3) arc (90:-180:2mm) -- (0,-0.3) arc (0:80:1mm) -- cycle (0.2,-0.5) circle (1mm);
\fill[black] (0,0) circle (0.5mm);
\end{scope}}

