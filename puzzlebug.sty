\newcommand{\scissor}[1][]{\begin{scope}[#1]
\draw[fill=white] (-0.1,0.7) arc (180:{90+tan(0.2/1.1)}:1mm) -- (0,0.8) -- (0.2,-0.3) arc (90:-180:2mm) -- (0,-0.3) arc (0:80:1mm) -- cycle (0.2,-0.5) circle (1mm);
\fill[black] (0,0) circle (0.5mm);
\end{scope}}

